# email-infra environment — copy to `.env` and fill in.
# `.env` is loaded automatically by dashboard.load_env() when running locally.
# ── Leave a value blank if you don't have it; V1 degrades gracefully. ──

# ========== REQUIRED for Health V1 ==========
SUPABASE_URL=            # THT infra Supabase project URL (https://<ref>.supabase.co)
SUPABASE_KEY=            # its service_role key
SMARTLEAD_JWT=           # SmartLead session token (browser dev tools) — pulls per-inbox health; EXPIRES, refresh when health stops updating
SMARTLEAD_API_KEY=       # SmartLead public API key — full sync so inboxes show client/group

# ========== Needed only for the cancel action ==========
ZAPMAIL_API_KEY=         # remove-on-renewal + subscriptions/billing

# ========== Optional (V1 runs without these) ==========
DASHBOARD_PASSWORD=      # blank = auth disabled locally
SMARTLEAD_GQL=           # has a working default, usually skip
CRM_SUPABASE_URL=        # nicer client-name matching
CRM_SUPABASE_KEY=

# ========== Only for the rest of the existing app (not V1) ==========
ZAPMAIL_EMAIL=
ZAPMAIL_PASSWORD=
SPACESHIP_API_KEY=
SPACESHIP_SECRET_KEY=
SPACESHIP_CONTACT_ID=
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=
GOOGLE_TOKEN_JSON=
SLACK_WEBHOOK_URL=
MARSHA_SLACK_WEBHOOK=
MARSHA_SLACK_CHANNEL=
ENABLE_MONITOR=
