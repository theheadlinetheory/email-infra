{
  "functions": {
    "api/index.py": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/health-snapshot", "schedule": "0 13 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }] }
  ]
}
